# Production environment (example)
# Copy to: .envs/production/.env.production
#
# Prefer generating a real file via:
# - scripts/docker/generate-env.sh
# - scripts/docker/generate-env.ps1

# Next.js Public Config
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Database (REQUIRED)
POSTGRES_DB=banking
POSTGRES_PASSWORD=
DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@db:5432/banking

# Auth & Security (REQUIRED)
ENCRYPTION_KEY=
NEXTAUTH_SECRET=

# Redis
REDIS_PASSWORD=
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# Node Environment
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# Traefik/Let's Encrypt
LETSENCRYPT_EMAIL=admin@yourdomain.com
# LETSENCRYPT_CA_SERVER=https://acme-v02.api.letsencrypt.org/directory

# Plaid Integration (optional)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_BASE_URL=https://sandbox.plaid.com
PLAID_PRODUCTS=
PLAID_COUNTRY_CODES=

# Dwolla Integration (optional)
DWOLLA_KEY=
DWOLLA_SECRET=
DWOLLA_ENV=sandbox
DWOLLA_BASE_URL=https://api-sandbox.dwolla.com

# Email Configuration (optional)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
