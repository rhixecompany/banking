# Local Docker Compose environment (example)
# Copy to: .envs/local/.env.local
#
# IMPORTANT:
# - Do not commit your real .env.local
# - For production, use scripts/docker/generate-env.* to generate secrets

# App URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Required in production (recommended to set locally too)
ENCRYPTION_KEY=
NEXTAUTH_SECRET=

# Database (Compose service name is `db`)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=banking
DATABASE_URL=postgresql://postgres:postgres@db:5432/banking

# Redis (Compose service name is `redis`)
REDIS_PASSWORD=redis
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# Auth (optional)
NEXTAUTH_URL=http://localhost:3000
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Plaid (optional)
PLAID_ENV=sandbox
PLAID_BASE_URL=https://sandbox.plaid.com
PLAID_CLIENT_ID=
PLAID_SECRET=

# Dwolla (optional)
DWOLLA_ENV=sandbox
DWOLLA_BASE_URL=https://api-sandbox.dwolla.com
DWOLLA_KEY=
DWOLLA_SECRET=

# Email (optional)
EMAIL_FROM=
SMTP_FROM=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# Test helpers (optional)
ENABLE_TEST_ENDPOINTS=
PLAYWRIGHT_BASE_URL=
