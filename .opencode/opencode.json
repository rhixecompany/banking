{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "compaction": {
    "auto": true
  },
  "experimental": {
    "quotaToast": {
      "enabledProviders": "auto",
      "enableToast": true,
      "formatStyle": "classic",
      "showSessionTokens": true
    }
  },
  "instructions": [
    "instructions/personas-list.md",
    "instructions/00-quickstart-rules.md",
    "instructions/09-command-plan-steps-rules.md"
  ],
  "mcp": {
    "filesystem": {
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "./",
        "~/"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "memory": {
      "command": ["npx", "-y", "@modelcontextprotocol/server-memory"],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "next-devtools": {
      "command": ["npx", "-y", "next-devtools-mcp@latest"],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "playwright": {
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "sequential-thinking": {
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "shadcn": {
      "command": ["npx", "shadcn@latest", "mcp"],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "youtube-transcript": {
      "command": [
        "npx",
        "-y",
        "@kimtaeyoon83/mcp-server-youtube-transcript"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    }
  },
  "model": "github-copilot/gpt-5-mini",
  "plugin": [
    "@gotgenes/opencode-agent-identity",
    "opencode-agent-memory",
    "opencode-agent-skills",
    "opencode-devcontainers",
    "@zenobius/opencode-background",
    "open-plan-annotator",
    "opencode-handoff",
    "@slkiser/opencode-quota",
    "@howaboua/opencode-planning-toolkit",
    "opencode-sessions"
  ]
}
