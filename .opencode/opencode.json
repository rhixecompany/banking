{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "command": {
    "mystatus": {
      "description": "Query quota usage for all AI accounts",
      "template": "Use the mystatus tool to query quota usage. Return the result as-is without modification."
    }
  },
  "compaction": {
    "auto": true
  },
  "default_agent": "nextjs-16-architect",
  "instructions": [
    "rules/code-review.md",
    "rules/commit-messages.md",
    "rules/debugging.md",
    "rules/documentation.md",
    "rules/github-session-limits.md",
    "rules/memory-bank.md",
    "rules/nextjs-tailwind.md",
    "rules/performance.md",
    "rules/playwright-typescript.md",
    "rules/security.md",
    "rules/task-implementation.md",
    "rules/tasksync.md",
    "rules/testing.md",
    "rules/typescript.md",
    "rules/update-docs-on-code-change.md",
    "rules/planning.md",
    "rules/building.md"
  ],
  "lsp": true,
  "mcp": {
    "context7": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "exa": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp"
    },
    "filesystem": {
      "command": [
        "bunx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "C:/Users/Alexa/Desktop/SandBox/Banking"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "gh_grep": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "github-agentic-workflows": {
      "command": [
        "bunx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "memory": {
      "command": [
        "bunx",
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "next-devtools": {
      "command": [
        "bunx",
        "-y",
        "next-devtools-mcp@latest"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "playwright": {
      "command": [
        "bunx",
        "-y",
        "@playwright/mcp@latest",
        "--caps=network,storage,testing,vision,pdf,devtools"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "sequential-thinking": {
      "command": [
        "bunx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "with-context": {
      "command": [
        "bunx",
        "-y",
        "with-context-mcp"
      ],
      "enabled": true,
      "environment": {
        "OBSIDIAN_API_KEY": "{env:OBSIDIAN_API_KEY}",
        "OBSIDIAN_API_URL": "{env:OBSIDIAN_API_URL}",
        "OBSIDIAN_VAULT": "{env:OBSIDIAN_VAULT}",
        "PROJECT_BASE_PATH": "{env:PROJECT_BASE_PATH}"
      },
      "type": "local"
    }
  },
  "model": "opencode/minimax-m2.5-free",
  "plugin": [
    "opencode-handoff",
    "@tarquinen/opencode-dcp",
    "@spoons-and-mirrors/subtask2",
    "@tarquinen/opencode-smart-title",
    "opencode-optimal-model-temps",
    "@nick-vi/opencode-type-inject",
    "octto",
    "@howaboua/opencode-planning-toolkit",
    "@zenobius/opencode-background",
    "opencode-froggy",
    "@openhax/codex",
    "file:///C:/Users/Alexa/Desktop/SandBox/Banking/.opencode/plugin-src/superpowers",
    "smart-codebase",
    "opencode-mystatus",
    "@slkiser/opencode-quota",
    "opencode-gemini-auth",
    "micode"
  ],
  "provider": {
    "anthropic": {
      "models": {
        "claude-haiku-4-5": {
          "temperature": true
        },
        "claude-opus-4-6": {
          "temperature": true
        },
        "claude-sonnet-4-6": {
          "temperature": true
        }
      },
      "options": {
        "apiKey": "{env:ANTHROPIC_API_KEY}"
      }
    },
    "calculon": {
      "models": {
        "gemma-4-e4b-it-8bit": {
          "attachment": true,
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "name": "gemma-4-e4b-it-8bit"
        },
        "Qwen3.5-9B-MLX-4bit": {
          "attachment": true,
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "name": "Qwen3.5-9B-MLX-4bit"
        }
      },
      "name": "calculon",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "{env:OMLX_API_KEY}",
        "baseURL": "http://calculon.local:8000/v1"
      }
    },
    "github-copilot": {
      "models": {
        "claude-haiku-4.5": {
          "name": "Claude Haiku 4.5",
          "temperature": true
        },
        "claude-opus-4.5": {
          "name": "Claude Opus 4.5",
          "temperature": true
        },
        "claude-sonnet-4.5": {
          "name": "Claude Sonnet 4.5",
          "temperature": true
        },
        "claude-sonnet-4.6": {
          "name": "Claude Sonnet 4.6",
          "temperature": true
        },
        "gemini-2.5-pro": {
          "name": "Gemini 2.5 Pro",
          "temperature": true
        },
        "gemini-3-flash-preview": {
          "name": "Gemini 3 Flash Preview",
          "temperature": true
        },
        "gemini-3.1-pro-preview": {
          "name": "Gemini 3.1 Pro Preview",
          "temperature": true
        },
        "gpt-4.1": {
          "name": "GPT-4.1",
          "temperature": true
        },
        "gpt-4o": {
          "name": "GPT-4o",
          "temperature": true
        },
        "gpt-4o-mini": {
          "name": "GPT-4o Mini",
          "temperature": true
        },
        "gpt-5-mini": {
          "name": "GPT-5 Mini",
          "temperature": true
        },
        "gpt-5.2": {
          "name": "GPT-5.2",
          "temperature": true
        },
        "gpt-5.2-codex": {
          "name": "GPT-5.2 Codex",
          "temperature": true
        },
        "gpt-5.3-codex": {
          "name": "GPT-5.3 Codex",
          "temperature": true
        },
        "gpt-5.4": {
          "name": "GPT-5.4",
          "temperature": true
        },
        "gpt-5.4-mini": {
          "name": "GPT-5.4 Mini",
          "temperature": true
        },
        "grok-code-fast-1": {
          "name": "Grok Code Fast 1",
          "temperature": true
        },
        "o1-mini": {
          "name": "o1 Mini",
          "temperature": false
        },
        "o1-preview": {
          "name": "o1 Preview",
          "temperature": false
        }
      },
      "options": {
        "include": [
          "reasoning.encrypted_content"
        ],
        "reasoningEffort": "medium",
        "reasoningSummary": "auto"
      }
    },
    "google-vertex": {
      "models": {
        "gemini-2.5-flash": {
          "temperature": true
        },
        "gemini-2.5-pro": {
          "temperature": true
        },
        "gemini-3.1-pro-preview": {
          "temperature": true
        }
      },
      "options": {
        "location": "{env:VERTEXAI_REGION}",
        "project": "{env:VERTEXAI_PROJECT_ID}"
      }
    },
    "openai": {
      "models": {
        "gpt-5.1-codex-max": {
          "name": "GPT 5.1 Codex Max (OAuth)",
          "temperature": true
        }
      },
      "options": {
        "include": [
          "reasoning.encrypted_content"
        ],
        "reasoningEffort": "medium",
        "reasoningSummary": "auto",
        "store": false,
        "textVerbosity": "medium"
      }
    },
    "opencode": {
      "models": {
        "deepseek-chat": {
          "name": "DeepSeek Chat",
          "temperature": true
        },
        "minimax-m2.1-free": {
          "name": "MiniMax M2.1 Free",
          "temperature": true
        },
        "minimax-m2.5-free": {
          "name": "MiniMax M2.5 Free",
          "temperature": true
        },
        "qwen-coder-turbo": {
          "name": "Qwen Coder Turbo",
          "temperature": true
        }
      },
      "options": {}
    },
    "openrouter": {
      "models": {
        "anthropic/claude-3-5-haiku": {
          "name": "Claude 3.5 Haiku (via OpenRouter)",
          "temperature": true
        },
        "anthropic/claude-3-5-sonnet": {
          "name": "Claude 3.5 Sonnet (via OpenRouter)",
          "temperature": true
        },
        "deepseek/deepseek-chat": {
          "name": "DeepSeek Chat",
          "temperature": true
        },
        "google/gemini-2.0-flash-exp": {
          "name": "Gemini 2.0 Flash Experimental",
          "temperature": true
        },
        "meta-llama/llama-3.3-70b-instruct": {
          "name": "Llama 3.3 70B Instruct",
          "temperature": true
        },
        "mistralai/mistral-large": {
          "name": "Mistral Large",
          "temperature": true
        },
        "openai/gpt-4o": {
          "name": "GPT-4o (via OpenRouter)",
          "temperature": true
        },
        "openai/gpt-4o-mini": {
          "name": "GPT-4o Mini (via OpenRouter)",
          "temperature": true
        }
      },
      "options": {
        "apiKey": "{env:OPENROUTER_API_KEY}"
      }
    }
  },
  "watcher": {
    "ignore": [
      "node_modules"
    ]
  }
}
