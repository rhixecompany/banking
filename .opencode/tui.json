{
  "$schema": "https://opencode.ai/tui.json",
  "diff_style": "auto",
  "keybinds": {
    "leader": "ctrl+x"
  },
  "mouse": true,
  "plugin": [
    "@gotgenes/opencode-agent-identity@latest",
    "opencode-agent-memory@latest",
    "opencode-agent-skills@latest",
    "opencode-devcontainers@latest",
    "@zenobius/opencode-background@latest",
    "open-plan-annotator@latest",
    "opencode-handoff@latest",
    "@slkiser/opencode-quota@latest",
    "@howaboua/opencode-planning-toolkit@latest",
    "opencode-sessions@latest",
    "opencode-supermemory@latest",
    "opencode-plugin-opencoder@latest",
    "@tarquinen/opencode-dcp@latest",
    "@franlol/opencode-md-table-formatter@latest"
  ],
  "plugin_enabled": {
    "@franlol/opencode-md-table-formatter": true,
    "@gotgenes/opencode-agent-identity": true,
    "@howaboua/opencode-planning-toolkit": true,
    "@slkiser/opencode-quota": true,
    "@tarquinen/opencode-dcp": true,
    "@zenobius/opencode-background": true,
    "open-plan-annotator": true,
    "opencode-agent-memory": true,
    "opencode-agent-skills": true,
    "opencode-devcontainers": true,
    "opencode-handoff": true,
    "opencode-plugin-opencoder": true,
    "opencode-sessions": true,
    "opencode-supermemory": true
  },
  "scroll_acceleration": {
    "enabled": true
  },
  "scroll_speed": 3,
  "theme": "ayu-dark"
}
