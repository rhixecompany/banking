{
  "$schema": "https://opencode.ai/tui.json",
  "diff_style": "auto",
  "keybinds": {
    "leader": "ctrl+x"
  },
  "mouse": true,
  "plugin": [
    "@gotgenes/opencode-agent-identity",
    "opencode-agent-memory",
    "opencode-agent-skills",
    "opencode-devcontainers",
    "@zenobius/opencode-background",
    "open-plan-annotator",
    "opencode-handoff",
    "opencode-mem",
    "@slkiser/opencode-quota",
    "@howaboua/opencode-planning-toolkit",
    "opencode-sessions"
  ],
  "plugin_enabled": {
    "@gotgenes/opencode-agent-identity": true,
    "@howaboua/opencode-planning-toolkit": true,
    "@slkiser/opencode-quota": true,
    "@zenobius/opencode-background": true,
    "open-plan-annotator": true,
    "opencode-agent-memory": true,
    "opencode-agent-skills": true,
    "opencode-devcontainers": true,
    "opencode-handoff": true,
    "opencode-mem": true,
    "opencode-sessions": true
  },
  "scroll_acceleration": {
    "enabled": true
  },
  "scroll_speed": 3,
  "theme": "moonlight"
}
