{
  "agents": {
    "brainstormer": {
      "model": "openai/gpt-4o",
      "temperature": 0.8
    },
    "commander": {
      "maxTokens": 8192,
      // Configure reasoning effort per agent
      "thinking": {
        "budgetTokens": 100000,
        "type": "enabled"
      }
    }
  },
  "compactionThreshold": 0.5,
  "features": {
    "mindmodelInjection": true
  },
  "fragments": {
    "commander": [
      "custom-instructions.md"
    ]
  }
}
