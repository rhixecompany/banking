[
  {
    "$schema": "https://opencode.ai/config.json",
    "autoupdate": "notify",
    "compaction": {
      "auto": true
    },
    "experimental": {
      "quotaToast": {
        "enabledProviders": "auto",
        "enableToast": true,
        "formatStyle": "classic",
        "showSessionTokens": true
      }
    },
    "instructions": [
      "instructions/personas-list.md",
      "instructions/00-quickstart-rules.md",
      "instructions/09-command-plan-steps-rules.md",
      "instructions/morph-tools.md"
    ],
    "mcp": {
      "MCP_DOCKER": {
        "command": [
          "docker",
          "mcp",
          "gateway",
          "run",
          "--profile",
          "adminbot"
        ],
        "enabled": true,
        "timeout": 900000,
        "type": "local"
      },
      "shadcn": {
        "command": ["npx", "shadcn@latest", "mcp"],
        "enabled": true,
        "timeout": 900000,
        "type": "local"
      }
    },
    "model": "github-copilot/gpt-5-mini",
    "plugin": [
      "@gotgenes/opencode-agent-identity",
      "opencode-agent-memory",
      "opencode-agent-skills",
      "opencode-devcontainers",
      "@zenobius/opencode-background",
      "open-plan-annotator",
      "opencode-handoff",
      "oh-my-opencode-slim",
      "opencode-mem",
      "@slkiser/opencode-quota",
      "github:JRedeker/opencode-morph-fast-apply",
      "@howaboua/opencode-planning-toolkit",
      "opencode-sessions"
    ]
  },
  {
    "$schema": "https://opencode.ai/config.json",
    "agent": {
      "build": {
        "description": "Build and implement features for the Banking project",
        "model": "github-copilot/gpt-5-mini",
        "permission": {
          "bash": "allow",
          "codesearch": "allow",
          "edit": "allow",
          "external_directory": "allow",
          "glob": "allow",
          "grep": "allow",
          "list": "allow",
          "lsp": "allow",
          "MCP_DOCKER_*": "allow",
          "question": "allow",
          "read": "allow",
          "shadcn_*": "allow",
          "skill": "allow",
          "task": "allow",
          "todowrite": "allow",
          "webfetch": "allow",
          "websearch": "allow"
        },
        "temperature": 0.1
      },
      "Next.js Expert": {
        "description": "Expert Next.js 16 developer specializing in App Router, Server Components, Cache Components, Turbopack, and modern React patterns with TypeScript",
        "model": "github-copilot/gpt-5-mini",
        "permission": {
          "__originalKeys": [],
          "bash": "allow",
          "codesearch": "allow",
          "doom_loop": "allow",
          "edit": "allow",
          "external_directory": "allow",
          "glob": "allow",
          "grep": "allow",
          "list": "allow",
          "lsp": "allow",
          "MCP_DOCKER_*": "allow",
          "question": "allow",
          "read": "allow",
          "shadcn_*": "allow",
          "skill": "allow",
          "task": "allow",
          "todowrite": "allow",
          "webfetch": "allow",
          "websearch": "allow"
        },
        "temperature": 0.1
      },
      "plan": {
        "description": "Review and plan changes for the Banking project",
        "model": "github-copilot/gpt-5-mini",
        "permission": {
          "bash": "allow",
          "codesearch": "allow",
          "edit": "deny",
          "external_directory": "allow",
          "glob": "allow",
          "grep": "allow",
          "list": "allow",
          "lsp": "allow",
          "MCP_DOCKER_*": "allow",
          "question": "allow",
          "read": "allow",
          "shadcn_*": "allow",
          "skill": "allow",
          "task": "allow",
          "todowrite": "allow",
          "webfetch": "allow",
          "websearch": "allow"
        },
        "temperature": 0.1
      },
      "quick-thinker": {
        "description": "Fast reasoning with limited iterations",
        "permission": {
          "__originalKeys": [],
          "bash": "allow",
          "codesearch": "allow",
          "doom_loop": "allow",
          "edit": "allow",
          "external_directory": "allow",
          "glob": "allow",
          "grep": "allow",
          "list": "allow",
          "lsp": "allow",
          "MCP_DOCKER_*": "allow",
          "question": "allow",
          "read": "allow",
          "shadcn_*": "allow",
          "skill": "allow",
          "task": "allow",
          "todowrite": "allow",
          "webfetch": "allow",
          "websearch": "allow"
        },
        "prompt": "You are a quick thinker. Solve problems with minimal steps.",
        "steps": 20,
        "temperature": 0.1
      },
      "review": {
        "description": "Review code changes and PRs for the Banking project",
        "model": "github-copilot/gpt-5-mini",
        "permission": {
          "__originalKeys": [],
          "bash": "allow",
          "codesearch": "allow",
          "doom_loop": "allow",
          "edit": "allow",
          "external_directory": "allow",
          "glob": "allow",
          "grep": "allow",
          "list": "allow",
          "lsp": "allow",
          "MCP_DOCKER_*": "allow",
          "question": "allow",
          "read": "allow",
          "shadcn_*": "allow",
          "skill": "allow",
          "task": "allow",
          "todowrite": "allow",
          "webfetch": "allow",
          "websearch": "allow"
        },
        "temperature": 0.1
      }
    },
    "autoupdate": "notify",
    "command": {
      "build": {
        "agent": "build",
        "description": "Build the project",
        "template": "Run npm run build and verify the build succeeds. Report any errors."
      },
      "test": {
        "agent": "build",
        "description": "Run all tests",
        "template": "Run npm run test and report results. Show test coverage and any failures."
      },
      "validate": {
        "agent": "build",
        "description": "Run all validation checks",
        "template": "Run npm run validate and report results. Focus on Build errors, TypeScript errors, lint warnings, and test failures."
      }
    },
    "compaction": {
      "auto": true,
      "reserved": 4000
    },
    "default_agent": "Next.js Expert",
    "instructions": [
      "AGENTS.md",
      "docs/personas-list.md",
      ".opencode/instructions/00-task-sync-note.md",
      ".opencode/instructions/01-core-standards.md",
      ".opencode/instructions/02-nextjs-patterns.md",
      ".opencode/instructions/03-dal-patterns.md",
      ".opencode/instructions/04-auth-testing.md",
      ".opencode/instructions/05-ui-validation.md",
      ".opencode/instructions/06-commands-ref.md",
      ".opencode/instructions/07-upstream-error-handling.md",
      ".opencode/instructions/08-alibaba-rate-limit-handling.md",
      ".opencode/instructions/09-plan-file-standards.md",
      ".opencode/instructions/10-apply-patch-verification-fix.md",
      ".opencode/instructions/11-documentation-standards.md",
      ".opencode/instructions/12-scripts-patterns.md",
      "docs/sections/*.md"
    ],
    "mcp": {
      "MCP_DOCKER": {
        "command": [
          "docker",
          "mcp",
          "gateway",
          "run",
          "--profile",
          "adminbot"
        ],
        "enabled": true,
        "timeout": 900000,
        "type": "local"
      },
      "shadcn": {
        "command": ["npx", "shadcn@latest", "mcp"],
        "enabled": true,
        "timeout": 900000,
        "type": "local"
      }
    },
    "model": "github-copilot/gpt-5-mini",
    "permission": {
      "__originalKeys": [],
      "bash": "allow",
      "codesearch": "allow",
      "doom_loop": "allow",
      "edit": "allow",
      "external_directory": "allow",
      "glob": "allow",
      "grep": "allow",
      "list": "allow",
      "lsp": "allow",
      "MCP_DOCKER_*": "allow",
      "question": "allow",
      "read": "allow",
      "shadcn_*": "allow",
      "skill": "allow",
      "task": "allow",
      "todowrite": "allow",
      "webfetch": "allow",
      "websearch": "allow"
    },
    "provider": {
      "ollama": {
        "models": {
          "qwen3.5:4b": {
            "name": "Qwen 3.5 VL 4B"
          }
        },
        "name": "Ollama (local)",
        "npm": "@ai-sdk/openai-compatible",
        "options": {
          "baseURL": "http://127.0.0.1:11434/v1"
        }
      }
    },
    "watcher": {
      "ignore": ["node_modules", ".next", "dist", ".git", "*.log"]
    }
  }
]
