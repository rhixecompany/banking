{
  "compilerOptions": {
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0",
    "incremental": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "actions/*": ["./src/actions/*"],
      "app/*": ["./src/app/*"],
      "app-config": ["./app-config.ts"],
      "components/*": ["./src/components/*"],
      "constants/*": ["./src/constants/*"],
      "dal/*": ["./src/dal/*"],
      "database/*": ["./src/database/*"],
      "hooks/*": ["./src/hooks/*"],
      "lib/*": ["./src/lib/*"],
      "scripts/*": ["./scripts/*"],
      "scripts": ["./scripts"],
      "scripts/mcp-runner-lib": ["./scripts/mcp-runner-lib.ts"],
      "scripts/plan-ensure": ["./scripts/plan-ensure.ts"],
      "scripts/report-parser": ["./scripts/report-parser.ts"],
      "scripts/verify-rules": ["./scripts/verify-rules.ts"],
      "scripts/ts/docs/generate-markdown-catalog": [
        "./scripts/ts/docs/generate-markdown-catalog.ts"
      ],
      "stores/*": ["./src/stores/*"],
      "tests/*": ["./tests/*"],
      "types/*": ["./src/types/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2025",
    "types": [
      "bun",
      "node",
      "react",
      "react-dom",
      "vitest",
      "vitest/globals"
    ]
  },
  "exclude": ["node_modules"],
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "hooks/**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "eslint.config.mts",
    "**/*.d.ts"
  ]
}
