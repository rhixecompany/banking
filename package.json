{
  "name": "banking",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./scripts/generate/docs-gen.ts",
  "scripts": {
    "prebuild": "npm run clean && npm run type-check",
    "build": "cross-env NODE_OPTIONS='--max-old-space-size=4096' ./node_modules/next/dist/bin/next build",
    "postbuild": "next-sitemap --config next-sitemap.config.ts",
    "build:analyze": "cross-env ANALYZE=true cross-env NODE_OPTIONS='--max-old-space-size=4096' ./node_modules/next/dist/bin/next build",
    "prebuild:debug": "npm run clean && npm run type-check",
    "build:debug": "cross-env NODE_OPTIONS='--max-old-space-size=4096' ./node_modules/next/dist/bin/next build --debug-prerender",
    "prebuild:standalone": "npm run clean && npm run type-check",
    "build:standalone": "cross-env NEXT_OUTPUT_MODE=standalone next build",
    "check-updates": "npm-check-updates --deep -i",
    "ci:checks:run": "bash scripts/utils/run-ci-checks.sh",
    "ci:helpers:fast-check": "tsx scripts/utils/ci-helpers/fast-check.ts",
    "ci:helpers:git-commit": "tsx scripts/utils/ci-helpers/git-commit-helper.ts",
    "ci:helpers:lint-fix": "tsx scripts/utils/ci-helpers/lint-fix-wrapper.ts",
    "ci:helpers:parse": "tsx scripts/utils/ci-helpers/parse-reports.ts",
    "ci:helpers:report": "tsx scripts/utils/ci-helpers/report-parser.ts",
    "ci:helpers:run": "tsx scripts/utils/ci-helpers/index.ts",
    "ci:helpers:seed-prep": "tsx scripts/utils/ci-helpers/seed-prep.ts",
    "ci:helpers:targeted-test": "tsx scripts/utils/ci-helpers/targeted-test-runner.ts",
    "clean": "rimraf .next out dist build .turbo coverage .react-email playwright-report test-results nul",
    "clean:all": "npm run clean && rimraf node_modules package-lock.json playwright-report test-results nul",
    "clean:cache": "rimraf .next/cache playwright-report test-results nul",
    "contributors:add": "all-contributors add",
    "contributors:check": "all-contributors check",
    "contributors:generate": "all-contributors generate",
    "db:check": "drizzle-kit check --config drizzle.config.ts",
    "db:drop": "drizzle-kit drop --config drizzle.config.ts",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts || echo 'Drizzle not configured'",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "db:pull": "drizzle-kit introspect --config drizzle.config.ts",
    "db:push": "drizzle-kit push --config drizzle.config.ts",
    "db:reset": "npm run db:drop && npm run db:generate && npm run db:push",
    "db:seed": "cross-env PLAID_TOKEN_MODE=sandbox tsx --env-file=.env.local scripts/seed/run.ts",
    "db:studio": "drizzle-kit studio",
    "deploy:htpasswd:generate": "bash scripts/deploy/generate-htpasswd.sh",
    "deploy:run": "bash scripts/deploy/deploy.sh",
    "predev": "npm run clean",
    "dev": "cross-env NODE_OPTIONS='--max-old-space-size=4096' next dev",
    "dev:sh": "./dev.sh",
    "docker:build": "bash scripts/utils/build.sh",
    "docker:cleanup": "bash scripts/cleanup/cleanup-docker.sh",
    "docker:deploy:check": "bash scripts/docker/deploy-checklist.sh",
    "docker:env:generate": "bash scripts/docker/generate-env.sh",
    "docker:quickstart": "bash scripts/docker/docker-quickstart.sh",
    "docker:secrets:read": "bash scripts/utils/read-secrets.sh",
    "docs:cleanup": "bash scripts/cleanup/cleanup-docs.sh",
    "export:data": "tsx scripts/export-data.ts",
    "format": "prettier --config .prettierrc.ts --write .",
    "format:check": "npm run format && prettier --config .prettierrc.ts --check .",
    "format:markdown:check": "npx markdownlint-cli2 -c .markdownlintrc.json",
    "format:markdown:fix": "npx markdownlint-cli2 -c .markdownlintrc.json --fix",
    "generate:action": "tsx scripts/generate/action.ts",
    "generate:component": "tsx scripts/generate/component.ts",
    "generate:dal": "tsx scripts/generate/dal.ts",
    "generate:feature": "tsx scripts/generate/feature.ts",
    "git:fix:line-endings": "bash scripts/utils/fix-line-endings.sh",
    "lint": "cross-env NODE_OPTIONS='--max-old-space-size=4096' eslint --config eslint.config.mts . --format=compact",
    "lint:fix": "cross-env NODE_OPTIONS='--max-old-space-size=4096' eslint --config eslint.config.mts . --fix",
    "lint:fix:all": "cross-env NODE_OPTIONS='--max-old-space-size=4096' eslint --config eslint.config.mts . --fix --fix-type directive --fix-type problem --fix-type suggestion --fix-type layout --format=compact",
    "lint:strict": "cross-env NODE_OPTIONS='--max-old-space-size=4096' eslint --config eslint.config.mts . --max-warnings=0",
    "prepare": "husky",
    "registry:build": "npm run registry:generate && npm run registry:export",
    "registry:export": "tsx scripts/export-json.ts --pretty --output .opencode/registry.json",
    "registry:generate": "tsx scripts/generate-readme.ts",
    "registry:generate:readme": "tsx scripts/generate-readme.ts --all",
    "registry:validate": "tsx scripts/validate.ts",
    "scripts:list": "node -e \"const s=JSON.parse(require('fs').readFileSync('package.json','utf8')).scripts; Object.entries(s).filter(([k])=>k.includes(':')).forEach(([k,v])=>console.log(k+' => '+v));\"",
    "server:certs:generate": "bash scripts/server/gen-certs.sh",
    "server:setup": "bash scripts/server/server-setup.sh",
    "server:vps:setup": "bash scripts/server/vps-setup.sh",
    "start": "next start",
    "pretest": "npm run clean",
    "test": "npm run test:ui && npm run test:browser",
    "test:browser": "vitest --config=vitest.config.ts run .",
    "test:ui": "cross-env PLAYWRIGHT_PREPARE_DB=true playwright test --project=chromium",
    "test:ui:codegen": "playwright codegen --project=chromium",
    "test:ui:report": "playwright show-report --project=chromium",
    "type-check": "tsc --noEmit --pretty",
    "type-check:watch": "tsc --noEmit --pretty --watch",
    "type-gen": "next typegen",
    "upstash": "npx @upstash/qstash-cli dev",
    "validate": "npx tsx scripts/validate.ts --all && npm run build && npm run lint:strict && npm run test",
    "website:build": "npm run build && npm run website:data && npm run --prefix website build",
    "website:dev": "npm run website:data && npm run --prefix website dev",
    "website:preview": "npm run --prefix website preview"
  },
