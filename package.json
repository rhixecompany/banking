{
  "name": "banking",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./eng/update-readme.ts",
  "scripts": {
    "prebuild": "npm run clean && npx tsc --noEmit",
    "build": "cross-env NODE_OPTIONS='--max-old-space-size=4096' ./node_modules/next/dist/bin/next build",
    "postbuild": "npx next-sitemap --config next-sitemap.config.ts",
    "build:analyze": "cross-env ANALYZE=true cross-env NODE_OPTIONS='--max-old-space-size=4096' ./node_modules/next/dist/bin/next build",
    "build:debug": "cross-env NODE_OPTIONS='--max-old-space-size=4096' ./node_modules/next/dist/bin/next build --debug-prerender",
    "build:standalone": "cross-env NEXT_OUTPUT_MODE=standalone next build",
    "check-updates": "npm-check-updates --deep -i",
    "clean": "rimraf .next out dist build .turbo coverage .react-email playwright-report test-results nul",
    "clean:all": "npm run clean && rimraf node_modules package-lock.json playwright-report test-results nul",
    "clean:cache": "rimraf .next/cache playwright-report test-results nul",
    "contributors:add": "all-contributors add",
    "contributors:check": "all-contributors check",
    "contributors:generate": "all-contributors generate",
    "contributors:report": "tsx ./eng/contributor-report.ts",
    "db:check": "drizzle-kit check --config drizzle.config.ts",
    "db:drop": "drizzle-kit drop --config drizzle.config.ts",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts || echo 'Drizzle not configured'",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "db:pull": "drizzle-kit introspect --config drizzle.config.ts",
    "db:push": "drizzle-kit push --config drizzle.config.ts",
    "db:reset": "npm run db:drop && npm run db:generate && npm run db:push",
    "db:seed": "tsx scripts/seed/run.ts",
    "db:studio": "drizzle-kit studio",
    "predev": "npm run clean && npx tsc --noEmit",
    "dev": "cross-env NODE_OPTIONS='--max-old-space-size=4096' next dev",
    "dev:sh": "./dev.sh",
    "format": "prettier --write .",
    "format:check": "npm run format && prettier --check .",
    "lint": "cross-env NODE_OPTIONS='--max-old-space-size=4096' eslint . --format=compact",
    "lint:fix": "cross-env NODE_OPTIONS='--max-old-space-size=4096' eslint . --fix",
    "lint:fix:all": "cross-env NODE_OPTIONS='--max-old-space-size=4096' eslint . --fix --fix-type directive --fix-type problem --fix-type suggestion --fix-type layout --format=compact",
    "lint:strict": "cross-env NODE_OPTIONS='--max-old-space-size=4096' eslint . --max-warnings=0",
    "plugin:clean": "tsx ./eng/clean-materialized-plugins.ts",
    "plugin:create": "tsx ./eng/create-plugin.ts",
    "plugin:generate-marketplace": "tsx ./eng/generate-marketplace.ts",
    "plugin:validate": "tsx ./eng/validate-plugins.ts",
    "prepare": "husky",
    "registry:build": "npm run registry:generate && npm run registry:export",
    "registry:export": "tsx scripts/export-json.ts --pretty --output dist/registry.json",
    "registry:generate": "tsx scripts/generate-readme.ts",
    "registry:validate": "tsx scripts/validate.ts",
    "skill:create": "tsx ./eng/create-skill.ts",
    "skill:validate": "tsx ./eng/validate-skills.ts",
    "start": "next start",
    "pretest": "npm run clean && npm run type-gen",
    "test": "npm run test:browser && npm run test:ui",
    "test:browser": "vitest --config=vitest.config.ts run .",
    "test:ui": "cross-env PLAYWRIGHT_PREPARE_DB=true playwright test --project=chromium --retries=0 --workers=1",
    "test:ui:codegen": "playwright codegen --project=chromium --retries=0 --workers=1",
    "test:ui:report": "playwright show-report --project=chromium --retries=0 --workers=1",
    "type-check": "tsc --noEmit --pretty",
    "type-check:watch": "tsc --noEmit --pretty --watch",
    "type-gen": "next typegen",
    "upstash": "npx @upstash/qstash-cli dev",
    "validate": "npm run format:check && npm run type-check && npm run lint:strict && npm run test",
    "website:build": "npm run build && npm run website:data && npm run --prefix website build",
    "website:data": "tsx ./eng/generate-website-data.ts",
    "website:dev": "npm run website:data && npm run --prefix website dev",
    "website:preview": "npm run --prefix website preview"
  },
