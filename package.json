{
  "name": "banking",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "pnpm clean && pnpm type-gen",
    "build": "cross-env NODE_OPTIONS='--max-old-space-size=4096' ./node_modules/next/dist/bin/next build",
    "postbuild": "pnpm next-sitemap --config next-sitemap.config.ts",
    "build:analyze": "cross-env ANALYZE=true cross-env NODE_OPTIONS='--max-old-space-size=4096' ./node_modules/next/dist/bin/next build",
    "build:debug": "cross-env NODE_OPTIONS='--max-old-space-size=4096' ./node_modules/next/dist/bin/next build --debug-prerender",
    "build:standalone": "cross-env NEXT_OUTPUT_MODE=standalone next build",
    "check-updates": "npm-check-updates --deep -i",
    "clean": "rimraf .next out dist build .turbo coverage .react-email",
    "clean:all": "pnpm clean && rimraf node_modules pnpm-lock.yaml",
    "clean:cache": "rimraf .next/cache",
    "db:check": "drizzle-kit check --config drizzle.config.ts",
    "db:drop": "drizzle-kit drop --config drizzle.config.ts",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts || echo 'Drizzle not configured'",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts",
    "db:pull": "drizzle-kit introspect --config drizzle.config.ts",
    "db:push": "drizzle-kit push --config drizzle.config.ts",
    "db:reset": "pnpm db:drop && pnpm db:generate && pnpm db:push",
    "db:studio": "drizzle-kit studio",
    "predev": "pnpm clean && pnpm type-gen",
    "dev": "cross-env NODE_OPTIONS='--max-old-space-size=4096' next dev",
    "dev:sh": "./dev.sh",
    "format": "prettier --write .",
    "format:check": "pnpm format && prettier --check .",
    "lint": "cross-env NODE_OPTIONS='--max-old-space-size=4096' eslint . --format=compact",
    "lint:fix": "cross-env NODE_OPTIONS='--max-old-space-size=4096' eslint . --fix",
    "lint:fix:all": "cross-env NODE_OPTIONS='--max-old-space-size=4096' eslint . --fix --fix-type directive --fix-type problem --fix-type suggestion --fix-type layout --format=compact",
    "lint:strict": "cross-env NODE_OPTIONS='--max-old-space-size=4096' eslint . --max-warnings=0",
    "prepare": "husky",
    "start": "next start",
    "pretest": "pnpm clean && pnpm type-gen",
    "test": "pnpm test:browser && pnpm test:ui",
    "test:browser": "vitest --config=vitest.config.ts run .",
    "test:ui": "pnpm exec playwright test",
    "test:ui:codegen": "pnpm exec playwright codegen",
    "test:ui:example": "pnpm exec playwright test example",
    "test:ui:report": "pnpm exec playwright show-report",
    "type-check": "tsc --noEmit --pretty",
    "type-check:watch": "tsc --noEmit --pretty --watch",
    "type-gen": "next typegen",
    "upstash": "pnpm dlx @upstash/qstash-cli dev",
    "validate": "pnpm format:check && pnpm type-check && pnpm lint:strict && pnpm test"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@sentry/nextjs": "^10.45.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "dwolla-v2": "^3.4.0",
    "lucide-react": "^1.0.1",
    "next": "16.2.1",
    "next-auth": "^4.24.13",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.3",
    "pg": "^8.20.0",
    "plaid": "^41.4.0",
    "query-string": "^9.3.1",
    "react": "^19",
    "react-chartjs-2": "^5.3.1",
    "react-countup": "^6.5.3",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19",
    "react-hook-form": "^7.72.0",
    "react-plaid-link": "^4.1.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@auth/drizzle-adapter": "^1.11.1",
    "@eslint/eslintrc": "^3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcrypt": "^6.0.0",
    "@types/fs-extra": "^11.0.4",
    "@types/ms": "^2.1.0",
    "@types/node": "^25",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.1",
    "@vitest/browser-preview": "^4.1.1",
    "babel-plugin-react-compiler": "1.0.0",
    "commander": "^14.0.3",
    "cross-env": "^10.1.0",
    "cspell": "^9.7.0",
    "dotenv": "^17.3.1",
    "dotenv-safe": "^9.1.0",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "dts-gen": "^0.10.9",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-formatter-compact": "^9.0.1",
    "eslint-plugin-better-tailwindcss": "^4.3.2",
    "eslint-plugin-drizzle": "^0.2.3",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jest": "^29.15.0",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-perfectionist": "^5.6.0",
    "eslint-plugin-playwright": "^2.9.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-testing-library": "^7.16.0",
    "eslint-plugin-unicorn": "^63.0.0",
    "eslint-plugin-vitest": "^0.5.4",
    "eslint-plugin-zod": "^3.5.0",
    "glob": "^13.0.6",
    "globals": "^17.4.0",
    "globby": "^16.1.1",
    "happy-dom": "^20.8.4",
    "husky": "^9.1.7",
    "inquirer": "^13.3.0",
    "jscodeshift": "^17.3.0",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.3",
    "ms": "^2.1.3",
    "next-sitemap": "^4.2.3",
    "npm-check-updates": "^19.6.3",
    "postcss": "^8",
    "postcss-import": "^16.1.1",
    "postcss-nested": "^7.0.2",
    "postcss-preset-env": "^11.2.0",
    "postgres": "^3.4.8",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-packagejson": "^3.0.2",
    "prettier-plugin-sort-json": "^4.2.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "pretty-quick": "^4.2.2",
    "redis": "^5.11.0",
    "rimraf": "^6.1.3",
    "shadcn": "^4.0.6",
    "tailwind-scrollbar": "^4.0.2",
    "tailwindcss": "^4",
    "ts-morph": "^27.0.2",
    "ts-stub": "^1.0.0",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "update-browserslist-db": "^1.2.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.0",
    "vitest-browser-react": "^2.1.0",
    "web-vitals": "^5.1.0"
  }
}
