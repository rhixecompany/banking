{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": "notify",
  "compaction": {
    "auto": true
  },
  "instructions": [
    ".opencode/instructions/00-quickstart-rules.md",
    ".opencode/instructions/09-command-plan-steps-rules.md",
    "AGENTS.md",
    "docs/personas-list.md",
    ".opencode/instructions/00-default-rules.md",
    ".cursorrules",
    ".github/copilot-instructions.md",
    ".opencode/instructions/*.md",
    ".github/instructions/*.md",
    ".cursor/rules/*.mdc"
  ],
  "mcp": {
    "MCP_DOCKER": {
      "command": [
        "docker",
        "mcp",
        "gateway",
        "run",
        "--profile",
        "adminbot"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "shadcn": {
      "command": ["npx", "shadcn@latest", "mcp"],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    }
  },
  "model": "github-copilot/gpt-5-mini"
}
