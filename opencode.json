{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "artifact-searcher": {
      "model": "openai/gpt-5.2"
    },
    "brainstormer": {
      "model": "openai/gpt-5.2"
    },
    "build": {
      "model": "openai/gpt-5.2"
    },
    "codebase-analyzer": {
      "model": "openai/gpt-5.2"
    },
    "codebase-locator": {
      "model": "openai/gpt-5.2"
    },
    "commander": {
      "model": "openai/gpt-5.2"
    },
    "executor": {
      "model": "openai/gpt-5.2"
    },
    "explore": {
      "model": "openai/gpt-5.2"
    },
    "implementer": {
      "model": "openai/gpt-5.2"
    },
    "ledger-creator": {
      "model": "openai/gpt-5.2"
    },
    "mm-orchestrator": {
      "model": "openai/gpt-5.2"
    },
    "pattern-finder": {
      "model": "openai/gpt-5.2"
    },
    "plan": {
      "model": "openai/gpt-5.2"
    },
    "planner": {
      "model": "openai/gpt-5.2"
    },
    "project-initializer": {
      "model": "openai/gpt-5.2"
    },
    "reviewer": {
      "model": "openai/gpt-5.2"
    }
  },
  "autoupdate": true,
  "command": {
    "mystatus": {
      "description": "Query quota usage for all AI accounts",
      "template": "Use the mystatus tool to query quota usage. Return the result as-is without modification."
    }
  },
  "compaction": {
    "auto": true
  },
  "experimental": {
    "batch_tool": true,
    "continue_loop_on_deny": true,
    "disable_paste_summary": true,
    "mcp_timeout": 6,
    "openTelemetry": true,
    "primary_tools": []
  },
  "instructions": [
    "AGENTS.md",
    "./architecture.md",
    "./tech-stack.md",
    "./coding-standards.md",
    "./folder-structure.md",
    "./exemplars.md",
    "./.github/copilot-instructions.md",
    "./.cursorrules",
    "./.opencode/instructions/*.md",
    "./.github/instructions/*.md",
    "./.cursor/rules/*.mdc"
  ],
  "mcp": {
    "context7": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "exa": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp"
    },
    "filesystem": {
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "~/"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "gh_grep": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "github-agentic-workflows": {
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "hostinger": {
      "command": [
        "npx",
        "-y",
        "hostinger-api-mcp"
      ],
      "environment": {
        "APITOKEN": "kB41t7SKoPaHNCAOZZsVpT12AGCBiMLcWcGxFIv4cd342fc7",
        "DEBUG": "false"
      },
      "timeout": 5000,
      "type": "local"
    },
    "memory": {
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "next-devtools": {
      "command": [
        "npx",
        "-y",
        "next-devtools-mcp@latest"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "playwright": {
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "sequential-thinking": {
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "shadcn": {
      "command": [
        "npx",
        "shadcn@latest",
        "mcp"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "youtube-transcript": {
      "command": [
        "npx",
        "-y",
        "@kimtaeyoon83/mcp-server-youtube-transcript"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    }
  },
  "model": "openai/gpt-5.2",
  "plugin": [
    "micode",
    "opencode-handoff",
    "opencode-beads",
    "@tarquinen/opencode-dcp",
    "@ramarivera/opencode-model-announcer",
    "github:JRedeker/opencode-morph-fast-apply",
    "open-plan-annotator",
    "opentmux",
    "opencode-ignore",
    "opencode-mem",
    "opencode-synced",
    "opencode-snippets",
    "opencode-mystatus",
    "@gotgenes/opencode-agent-identity",
    "opencode-agent-memory",
    "opencode-agent-skills",
    "opencode-devcontainers",
    "@zenobius/opencode-background",
    "@slkiser/opencode-quota",
    "opencode-sessions",
    "@franlol/opencode-md-table-formatter",
    "@liannnix/opencode-ntfy",
    "@howaboua/opencode-planning-toolkit"
  ],
  "watcher": {
    "ignore": [
      "node_modules",
      ".next",
      "dist",
      ".git",
      "*.log"
    ]
  }
}
