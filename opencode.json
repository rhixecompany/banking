{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "model": "opencode/minimax-m2.5-free"
    },
    "compaction": {
      "model": "opencode/minimax-m2.5-free"
    },
    "explore": {
      "model": "opencode/minimax-m2.5-free"
    },
    "general": {
      "model": "opencode/minimax-m2.5-free"
    },
    "Octto": {
      "model": "opencode/minimax-m2.5-free"
    },
    "plan": {
      "model": "github-copilot/gpt-5-mini",
      "variant": "high"
    },
    "summary": {
      "model": "opencode/minimax-m2.5-free"
    },
    "title": {
      "model": "opencode/minimax-m2.5-free"
    }
  },
  "autoupdate": true,
  "command": {
    "mystatus": {
      "description": "Query quota usage for all AI accounts",
      "template": "Use the mystatus tool to query quota usage. Return the result as-is without modification."
    }
  },
  "compaction": {
    "auto": true
  },
  "instructions": [
    "./.opencode/instructions/index.md"
  ],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "exa": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp"
    },
    "filesystem": {
      "command": [
        "bunx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "~/"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "gh_grep": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "github-agentic-workflows": {
      "command": [
        "bunx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "hostinger": {
      "command": [
        "bunx",
        "-y",
        "hostinger-api-mcp"
      ],
      "environment": {
        "DEBUG": "false"
      },
      "timeout": 5000,
      "type": "local"
    },
    "memory": {
      "command": [
        "bunx",
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "next-devtools": {
      "command": [
        "bunx",
        "-y",
        "next-devtools-mcp@latest"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "playwright": {
      "command": [
        "bunx",
        "-y",
        "@playwright/mcp@latest"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "sequential-thinking": {
      "command": [
        "bunx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "shadcn": {
      "command": [
        "bunx",
        "shadcn@latest",
        "mcp"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "youtube-transcript": {
      "command": [
        "bunx",
        "-y",
        "@kimtaeyoon83/mcp-server-youtube-transcript"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    }
  },
  "model": "opencode/minimax-m2.5-free",
  "plugin": [
    "opencode-handoff",
    "opencode-beads",
    "@tarquinen/opencode-dcp",
    "@ramarivera/opencode-model-announcer",
    "open-plan-annotator",
    "opencode-ignore",
    "opencode-synced",
    "opencode-snippets",
    "opencode-mystatus",
    "@gotgenes/opencode-agent-identity",
    "opencode-agent-memory",
    "opencode-agent-skills",
    "opencode-devcontainers",
    "@zenobius/opencode-background",
    "opencode-sessions",
    "@franlol/opencode-md-table-formatter",
    "@liannnix/opencode-ntfy",
    "@howaboua/opencode-planning-toolkit",
    "github:JRedeker/opencode-morph-fast-apply",
    "opencode-mem",
    "@slkiser/opencode-quota",
    "smart-codebase",
    "superpowers@git+https://github.com/obra/superpowers.git",
    "octto"
  ],
  "watcher": {
    "ignore": [
      "node_modules",
      ".next",
      ".git"
    ]
  }
}
