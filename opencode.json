{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "description": "Build and implement features for the Banking project",
      "model": "opencode/big-pickle"
    },
    "plan": {
      "description": "Review and plan changes for the Banking project",
      "model": "opencode/big-pickle"
    },
    "review": {
      "description": "Review code changes and PRs for the Banking project",
      "model": "opencode/big-pickle"
    }
  },
  "autoupdate": true,
  "command": {
    "build": {
      "agent": "build",
      "description": "Build the project",
      "template": "Run npm run build and verify the build succeeds. Report any errors."
    },
    "test": {
      "agent": "build",
      "description": "Run all tests",
      "template": "Run npm run test and report results. Show test coverage and any failures."
    },
    "validate": {
      "agent": "build",
      "description": "Run all validation checks",
      "template": "Run npm run validate and report results. Focus on TypeScript errors, lint warnings, and test failures."
    }
  },
  "instructions": [
    "AGENTS.md",
    ".opencode/instructions/*.md"
  ],
  "mcp": {
    "MCP_DOCKER": {
      "command": [
        "docker",
        "mcp",
        "gateway",
        "run",
        "--profile",
        "adminbot"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "shadcn": {
      "command": [
        "npx",
        "shadcn@latest",
        "mcp"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    }
  },
  "model": "opencode/big-pickle",
  "watcher": {
    "ignore": [
      "node_modules",
      ".next",
      "dist",
      ".git",
      "*.log"
    ]
  }
}
