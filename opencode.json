{
  "$schema": "https://opencode.ai/config.json",
  "agent": {},
  "autoupdate": true,
  "compaction": {
    "auto": true
  },
  "experimental": {},
  "instructions": [
    "AGENTS.md",
    "./.github/copilot-instructions.md",
    "./.cursorrules",
    "./.opencode/instructions/personas-list.md",
    "./.opencode/instructions/00-quickstart-rules.md",
    "./.opencode/instructions/00-default-rules.md",
    "./.opencode/instructions/00-task-sync-note.md",
    "./.opencode/instructions/01-core-standards.md",
    "./.opencode/instructions/02-nextjs-patterns.md",
    "./.opencode/instructions/03-dal-patterns.md",
    "./.opencode/instructions/04-auth-testing.md",
    "./.opencode/instructions/05-ui-validation.md",
    "./.opencode/instructions/06-commands-ref.md",
    "./.opencode/instructions/07-upstream-error-handling.md",
    "./.opencode/instructions/08-command-plan-steps-rules.md",
    "./.opencode/instructions/09-command-plan-steps-rules.md",
    "./.opencode/instructions/09-plan-file-standards.md",
    "./.opencode/instructions/10-apply-patch-verification-fix.md",
    "./.opencode/instructions/11-documentation-standards.md",
    "./.opencode/instructions/12-scripts-patterns.md",
    "./.opencode/tools/philosophy.md",
    "./.cursor/rules/*.mdc",
    "./architecture.md",
    "./tech-stack.md",
    "./coding-standards.md",
    "./folder-structure.md",
    "./exemplars.md"
  ],
  "mcp": {
    "context7": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "exa": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp"
    },
    "filesystem": {
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "~/"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "gh_grep": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "github-agentic-workflows": {
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "memory": {
      "command": ["npx", "-y", "@modelcontextprotocol/server-memory"],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "next-devtools": {
      "command": ["npx", "-y", "next-devtools-mcp@latest"],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "playwright": {
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "sequential-thinking": {
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "shadcn": {
      "command": ["npx", "shadcn@latest", "mcp"],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "youtube-transcript": {
      "command": [
        "npx",
        "-y",
        "@kimtaeyoon83/mcp-server-youtube-transcript"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    }
  },
  "model": "github-copilot/gpt-5-mini",
  "plugin": [
    "@gotgenes/opencode-agent-identity@latest",
    "opencode-agent-memory@latest",
    "opencode-agent-skills@latest",
    "opencode-devcontainers@latest",
    "@zenobius/opencode-background@latest",
    "open-plan-annotator@latest",
    "opencode-handoff@latest",
    "@slkiser/opencode-quota@latest",
    "@howaboua/opencode-planning-toolkit@latest",
    "opencode-sessions@latest",
    "@tarquinen/opencode-dcp@latest",
    "@franlol/opencode-md-table-formatter@latest"
  ]
}
