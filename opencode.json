{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "description": "Build and implement features for the Banking project",
      "model": "github-copilot/gpt-5-mini",
      "permission": {
        "bash": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "lsp": "allow",
        "MCP_DOCKER_*": "allow",
        "question": "allow",
        "read": "allow",
        "shadcn_*": "allow",
        "skill": "allow",
        "todowrite": "allow",
        "webfetch": "allow",
        "websearch": "allow"
      },
      "temperature": 0.1
    },
    "Next.js Expert": {
      "description": "Next.js Expert agent for building and implementing features in the Banking project",
      "model": "github-copilot/gpt-5-mini",
      "permission": {
        "bash": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "lsp": "allow",
        "MCP_DOCKER_*": "allow",
        "question": "allow",
        "read": "allow",
        "shadcn_*": "allow",
        "skill": "allow",
        "todowrite": "allow",
        "webfetch": "allow",
        "websearch": "allow"
      },
      "temperature": 0.1
    },
    "plan": {
      "description": "Review and plan changes for the Banking project",
      "model": "github-copilot/gpt-5-mini",
      "permission": {
        "bash": "allow",
        "edit": "deny",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "lsp": "allow",
        "MCP_DOCKER_*": "allow",
        "question": "allow",
        "read": "allow",
        "shadcn_*": "allow",
        "skill": "allow",
        "todowrite": "allow",
        "webfetch": "allow",
        "websearch": "allow"
      },
      "steps": 20,
      "temperature": 0.2
    },
    "quick-thinker": {
      "description": "Fast reasoning with limited iterations",
      "permission": {
        "bash": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "lsp": "allow",
        "MCP_DOCKER_*": "allow",
        "question": "allow",
        "read": "allow",
        "shadcn_*": "allow",
        "skill": "allow",
        "todowrite": "allow",
        "webfetch": "allow",
        "websearch": "allow"
      },
      "prompt": "You are a quick thinker. Solve problems with minimal steps.",
      "steps": 20,
      "temperature": 0.1
    },
    "review": {
      "description": "Review code changes and PRs for the Banking project",
      "model": "github-copilot/gpt-5-mini",
      "permission": {
        "bash": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "lsp": "allow",
        "MCP_DOCKER_*": "allow",
        "question": "allow",
        "read": "allow",
        "shadcn_*": "allow",
        "skill": "allow",
        "todowrite": "allow",
        "webfetch": "allow",
        "websearch": "allow"
      },
      "steps": 20,
      "temperature": 0.2
    }
  },
  "autoupdate": "notify",
  "command": {
    "build": {
      "agent": "build",
      "description": "Build the project",
      "template": "Run npm run build and verify the build succeeds. Report any errors."
    },
    "test": {
      "agent": "build",
      "description": "Run all tests",
      "template": "Run npm run test and report results. Show test coverage and any failures."
    },
    "validate": {
      "agent": "build",
      "description": "Run all validation checks",
      "template": "Run npm run validate and report results. Focus on Build errors, TypeScript errors, lint warnings, and test failures."
    }
  },
  "compaction": {
    "auto": false,
    "reserved": 10000
  },
  "default_agent": "Next.js Expert",
  "instructions": [
    "AGENTS.md",
    "docs/personas-list.md",
    ".opencode/instructions/00-task-sync-note.md",
    ".opencode/instructions/01-core-standards.md",
    ".opencode/instructions/02-nextjs-patterns.md",
    ".opencode/instructions/03-dal-patterns.md",
    ".opencode/instructions/04-auth-testing.md",
    ".opencode/instructions/05-ui-validation.md",
    ".opencode/instructions/06-commands-ref.md",
    ".opencode/instructions/07-upstream-error-handling.md",
    ".opencode/instructions/08-alibaba-rate-limit-handling.md",
    ".opencode/instructions/09-plan-file-standards.md",
    ".opencode/instructions/10-apply-patch-verification-fix.md",
    ".opencode/instructions/11-documentation-standards.md",
    ".opencode/plans/*.md"
  ],
  "mcp": {
    "MCP_DOCKER": {
      "command": [
        "docker",
        "mcp",
        "gateway",
        "run",
        "--profile",
        "adminbot"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "shadcn": {
      "command": ["npx", "shadcn@latest", "mcp"],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    }
  },
  "model": "github-copilot/gpt-5-mini",
  "permission": {
    "bash": "allow",
    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "lsp": "allow",
    "MCP_DOCKER_*": "allow",
    "question": "allow",
    "read": "allow",
    "shadcn_*": "allow",
    "skill": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow"
  },
  "watcher": {
    "ignore": ["node_modules", ".next", "dist", ".git", "*.log"]
  }
}
