{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "command": {
    "mystatus": {
      "description": "Query quota usage for all AI accounts",
      "template": "Use the mystatus tool to query quota usage. Return the result as-is without modification."
    }
  },
  "compaction": {
    "auto": true
  },
  "experimental": {},
  "instructions": [
    "AGENTS.md",
    "./architecture.md",
    "./tech-stack.md",
    "./coding-standards.md",
    "./folder-structure.md",
    "./exemplars.md",
    "./.github/copilot-instructions.md",
    "./.cursorrules",
    "./.opencode/instructions/*.md",
    "./.github/instructions/*.md",
    "./.cursor/rules/*.mdc"
  ],
  "mcp": {
    "context7": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "exa": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp"
    },
    "filesystem": {
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "~/"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "gh_grep": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "github-agentic-workflows": {
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "memory": {
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "next-devtools": {
      "command": [
        "npx",
        "-y",
        "next-devtools-mcp@latest"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "playwright": {
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "sequential-thinking": {
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "shadcn": {
      "command": [
        "npx",
        "shadcn@latest",
        "mcp"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "youtube-transcript": {
      "command": [
        "npx",
        "-y",
        "@kimtaeyoon83/mcp-server-youtube-transcript"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    }
  },
  "model": "opencode/minimax-m2.5-free",
  "plugin": [
    "micode",
    "opencode-handoff",
    "opencode-beads",
    "@tarquinen/opencode-dcp@latest",
    "@ramarivera/opencode-model-announcer",
    "github:JRedeker/opencode-morph-fast-apply",
    "open-plan-annotator@latest",
    "opentmux",
    "opencode-ignore",
    "opencode-mem",
    "opencode-ntfy.sh",
    "@howaboua/opencode-planning-toolkit@latest",
    "opencode-sessions",
    "opencode-synced",
    "opencode-snippets",
    "opencode-mystatus",
    "@gotgenes/opencode-agent-identity@latest",
    "opencode-agent-memory@latest",
    "opencode-agent-skills@latest",
    "opencode-devcontainers@latest",
    "@zenobius/opencode-background@latest",
    "open-plan-annotator@latest",
    "opencode-handoff@latest",
    "@slkiser/opencode-quota@latest",
    "@howaboua/opencode-planning-toolkit@latest",
    "opencode-sessions@latest",
    "@tarquinen/opencode-dcp@latest",
    "@franlol/opencode-md-table-formatter@latest"
  ],
"agent": {
    "commander": { "model": "openai/gpt-5.4" },
    "brainstormer": { "model": "openai/gpt-5.4" },
    "planner": { "model": "openai/gpt-5.4" },
    "executor": { "model": "openai/gpt-5.4" },
    "implementer": { "model": "openai/gpt-5.4" },
    "reviewer": { "model": "openai/gpt-5.4" },
    "codebase-locator": { "model": "openai/gpt-5.4" },
    "codebase-analyzer": { "model": "openai/gpt-5.4" },
    "pattern-finder": { "model": "openai/gpt-5.4" },
    "project-initializer": { "model": "openai/gpt-5.4" },
    "ledger-creator": { "model": "openai/gpt-5.4" },
    "artifact-searcher": { "model": "openai/gpt-5.4" },
    "mm-orchestrator": { "model": "openai/gpt-5.4" }
  },
}
