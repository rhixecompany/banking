{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    ".opencode/agents_quickstart.md",
    "AGENTS.md",
    "docs/personas-list.md",
    ".opencode/instructions/00-default-rules.md",
    "docs/app-pages.md",
    "docs/custom-components.md",
    "docs/test-context.md",
    ".cursorrules",
    ".github/copilot-instructions.md",
    ".opencode/instructions/*.md",
    ".opencode/skills/**/SKILL.md",
    ".cursor/skills/**/SKILL.md",
    ".cursor/rules/*.mdc"
  ],
  "mcp": {
    "MCP_DOCKER": {
      "command": [
        "docker",
        "mcp",
        "gateway",
        "run",
        "--profile",
        "adminbot"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "shadcn": {
      "command": [
        "npx",
        "shadcn@latest",
        "mcp"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    }
  },
  "model": "github-copilot/gpt-5-mini"
}
