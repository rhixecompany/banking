{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "description": "Build and implement features for the Banking project"
    },
    "plan": {
      "description": "Review and plan changes for the Banking project"
    },
    "review": {
      "description": "Review code changes and PRs for the Banking project"
    }
  },
  "autoupdate": false,
  "command": {
    "build": {
      "agent": "build",
      "description": "Build the project",
      "template": "Run npm run build and verify the build succeeds. Report any errors."
    },
    "test": {
      "agent": "build",
      "description": "Run all tests",
      "template": "Run npm run test and report results. Show test coverage and any failures."
    },
    "validate": {
      "agent": "build",
      "description": "Run all validation checks",
      "template": "Run npm run validate and report results. Focus on TypeScript errors, lint warnings, and test failures."
    }
  },
  "instructions": [
    "AGENTS.md",
    ".opencode/instructions/*.md",
    ".cursor/rules/*.mdc"
  ],
  "mcp": {
    "context7": {
      "enabled": true,
      "timeout": 90000,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "database-server": {
      "command": [
        "npx",
        "tsx",
        ".opencode/mcp-runner.ts",
        "@modelcontextprotocol/server-postgres"
      ],
      "enabled": true,
      "environment": {
        "DATABASE_URL": "{env:DATABASE_URL}"
      },
      "timeout": 90000,
      "type": "local"
    },
    "github-official": {
      "command": [
        "npx",
        "tsx",
        ".opencode/mcp-runner.ts",
        "@modelcontextprotocol/server-github"
      ],
      "enabled": true,
      "environment": {
        "GITHUB_TOKEN": "{env:GITHUB_TOKEN}"
      },
      "timeout": 90000,
      "type": "local"
    },
    "MCP_DOCKER": {
      "command": [
        "docker",
        "mcp",
        "gateway",
        "run",
        "--profile",
        "adminbot"
      ],
      "enabled": true,
      "timeout": 90000,
      "type": "local"
    },
    "neon": {
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:NEON_API_KEY}"
      },
      "timeout": 90000,
      "type": "remote",
      "url": "https://mcp.neon.tech/mcp"
    },
    "playwright": {
      "command": [
        "npx",
        "tsx",
        ".opencode/mcp-runner.ts",
        "@playwright/mcp"
      ],
      "enabled": true,
      "timeout": 120000,
      "type": "local"
    },
    "shadcn": {
      "command": ["npx", "shadcn@latest", "mcp"],
      "enabled": true,
      "timeout": 90000,
      "type": "local"
    }
  },
  "model": "github-copilot/claude-sonnet-4.6",
  "watcher": {
    "ignore": ["node_modules", ".next", "dist", ".git", "*.log"]
  }
}
