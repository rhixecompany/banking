{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "description": "Build and implement features for the Banking project"
    },
    "custom-agent": {
      "description": "Specialized coding agent using Qwen 3.6 Plus",
      "model": "opencode/minimax-m2.5-free",
      "temperature": 0.2,
      "tools": {
        "bash": true,
        "write": true
      }
    },
    "plan": {
      "description": "Review and plan changes for the Banking project"
    },
    "review": {
      "description": "Review code changes and PRs for the Banking project"
    }
  },
  "autoupdate": true,
  "command": {
    "build": {
      "agent": "build",
      "description": "Build the project",
      "template": "Run npm run build and verify the build succeeds. Report any errors."
    },
    "test": {
      "agent": "build",
      "description": "Run all tests",
      "template": "Run npm run test and report results. Show test coverage and any failures."
    },
    "validate": {
      "agent": "build",
      "description": "Run all validation checks",
      "template": "Run npm run validate and report results. Focus on Build errors, TypeScript errors, lint warnings, and test failures."
    }
  },
  "compaction": {
    "auto": true,
    "reserved": 8000
  },
  "instructions": [
    "AGENTS.md",
    ".opencode/instructions/*.md",
    "docs/README.md",
    "scripts/README.md",
    "README.md"
  ],
  "mcp": {
    "MCP_DOCKER": {
      "command": [
        "docker",
        "mcp",
        "gateway",
        "run",
        "--profile",
        "adminbot"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "shadcn": {
      "command": [
        "npx",
        "shadcn@latest",
        "mcp"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    }
  },
  "mode": {
    "build": {
      "model": "opencode/minimax-m2.5-free",
      "temperature": 0.55
    },
    "plan": {
      "model": "opencode/minimax-m2.5-free",
      "temperature": 0.2
    }
  },
  "model": "opencode/minimax-m2.5-free",
  "watcher": {
    "ignore": [
      "node_modules",
      ".next",
      "dist",
      ".git",
      "*.log"
    ]
  }
}
