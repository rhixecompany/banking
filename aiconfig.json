{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "model": "github-copilot/claude-haiku-4.5",
      "variant": "max"
    },
    "plan": {
      "model": "github-copilot/claude-sonnet-4.6",
      "variant": "high"
    }
  },
  "autoupdate": false,
  "command": {
    "mystatus": {
      "description": "Query quota usage for all AI accounts",
      "template": "Use the mystatus tool to query quota usage. Return the result as-is without modification."
    }
  },
  "compaction": {
    "auto": true
  },
  "default_agent": "build",
  "enabled_providers": [
    "google-vertex",
    "openrouter",
    "anthropic",
    "calculon",
    "openai",
    "opencode",
    "github-copilot"
  ],
  "instructions": [
    "rules/code-review.md",
    "rules/commit-messages.md",
    "rules/documentation.md",
    "rules/github-session-limits.md",
    "rules/memory-banks.md",
    "rules/nextjs-tailwind.md",
    "rules/performance.md",
    "rules/playwright-typescript.md",
    "rules/security.md",
    "rules/task-implementation.md",
    "rules/tasksync.md",
    "rules/testing.md",
    "rules/typescripts.md",
    "rules/update-docs-on-code-change.md"
  ],
  "lsp": true,
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "exa": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp"
    },
    "filesystem": {
      "command": [
        "bunx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "~/"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "gh_grep": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "github-agentic-workflows": {
      "command": [
        "bunx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "memory": {
      "command": [
        "bunx",
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "next-devtools": {
      "command": [
        "bunx",
        "-y",
        "next-devtools-mcp@latest"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "playwright": {
      "command": [
        "bunx",
        "-y",
        "@playwright/mcp@latest",
        "--caps=network,storage,testing,vision,pdf,devtools"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "sequential-thinking": {
      "command": [
        "bunx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    }
  },
  "model": "github-copilot/gpt-5.1-codex",
  "plugin": [
    "opencode-mystatus",
    "opencode-handoff",
    "@tarquinen/opencode-dcp",
    "superpowers@git+https://github.com/obra/superpowers.git",
    "@howaboua/opencode-planning-toolkit",
    "smart-codebase",
    "octto",
    "@nick-vi/opencode-type-inject",
    "@zenobius/opencode-skillful",
    "@slkiser/opencode-quota"
  ],
  "provider": {
    "anthropic": {
      "models": {
        "claude-haiku-4-5": {
          "temperature": true
        },
        "claude-opus-4-6": {
          "temperature": true
        },
        "claude-sonnet-4-6": {
          "temperature": true
        }
      },
      "options": {
        "apiKey": "{env:ANTHROPIC_API_KEY}"
      }
    },
    "calculon": {
      "models": {
        "gemma-4-e4b-it-8bit": {
          "attachment": true,
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "name": "gemma-4-e4b-it-8bit"
        },
        "Qwen3.5-9B-MLX-4bit": {
          "attachment": true,
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          },
          "name": "Qwen3.5-9B-MLX-4bit"
        }
      },
      "name": "calculon",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "{env:OMLX_API_KEY}",
        "baseURL": "http://calculon.local:8000/v1"
      }
    },
    "google-vertex": {
      "models": {
        "gemini-2.5-flash": {
          "temperature": true
        },
        "gemini-2.5-pro": {
          "temperature": true
        },
        "gemini-3.1-pro-preview": {
          "temperature": true
        }
      },
      "options": {
        "location": "{env:VERTEXAI_REGION}",
        "project": "{env:VERTEXAI_PROJECT_ID}"
      }
    }
  },
  "share": "auto",
  "small_model": "github-copilot/claude-haiku-4.5",
  "watcher": {
    "ignore": [
      "node_modules",
      "../node_modules",
      "../.next",
      "../.git"
    ]
  }
}
