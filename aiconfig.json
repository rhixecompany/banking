{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {},
    "plan": {}
  },
  "autoupdate": true,
  "command": {
    "mystatus": {
      "description": "Query quota usage for all AI accounts",
      "template": "Use the mystatus tool to query quota usage. Return the result as-is without modification."
    }
  },
  "compaction": {
    "auto": true
  },
  "default_agent": "plan",
  "enabled_providers": [
    "google-vertex",
    "openrouter",
    "anthropic",
    "calculon",
    "openai",
    "opencode",
    "github-copilot"
  ],
  "instructions": [
    "rules/code-review.md",
    "rules/commit-messages.md",
    "rules/debugging.md",
    "rules/documentation.md",
    "rules/github-session-limits.md",
    "rules/memory-bank.md",
    "rules/nextjs-tailwind.md",
    "rules/performance.md",
    "rules/playwright-typescript.md",
    "rules/security.md",
    "rules/task-implementation.md",
    "rules/tasksync.md",
    "rules/testing.md",
    "rules/typescript.md",
    "rules/update-docs-on-code-change.md",
    "rules/planning.md",
    "rules/building.md"
  ],
  "lsp": true,
  "mcp": {
    "context7": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "exa": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp"
    },
    "filesystem": {
      "command": [
        "bunx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "~/"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "gh_grep": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "github-agentic-workflows": {
      "command": [
        "bunx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "memory": {
      "command": [
        "bunx",
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "next-devtools": {
      "command": ["bunx", "-y", "next-devtools-mcp@latest"],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "playwright": {
      "command": [
        "bunx",
        "-y",
        "@playwright/mcp@latest",
        "--caps=network,storage,testing,vision,pdf,devtools"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "sequential-thinking": {
      "command": [
        "bunx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true,
      "timeout": 900000,
      "type": "local"
    },
    "with-context": {
      "command": ["bunx", "-y", "with-context-mcp"],
      "enabled": true,
      "environment": {
        "OBSIDIAN_API_KEY": "{env:OBSIDIAN_API_KEY}",
        "OBSIDIAN_API_URL": "{env:OBSIDIAN_API_URL}",
        "OBSIDIAN_VAULT": "{env:OBSIDIAN_VAULT}",
        "PROJECT_BASE_PATH": "{env:PROJECT_BASE_PATH}"
      },
      "type": "local"
    }
  },
  "model": "opencode/minimax-m2.5-free",
  "plugin": [
    "opencode-mystatus",
    "opencode-handoff",
    "@tarquinen/opencode-dcp",
    "superpowers@git+https://github.com/obra/superpowers.git",
    "@howaboua/opencode-planning-toolkit@latest",
    "smart-codebase",
    "octto",
    "@nick-vi/opencode-type-inject",
    "@zenobius/opencode-skillful",
    "@slkiser/opencode-quota",
    "@spoons-and-mirrors/subtask2@latest",
    "@tarquinen/opencode-smart-title",
    "opencode-optimal-model-temps",
    "@openhax/codex",
    "micode",
    "opencode-froggy",
    "@zenobius/opencode-background"
  ],
  "provider": {
    "anthropic": {
      "models": {
        "claude-haiku-4-5": {
          "temperature": true
        },
        "claude-opus-4-6": {
          "temperature": true
        },
        "claude-sonnet-4-6": {
          "temperature": true
        }
      },
      "options": {
        "apiKey": "{env:ANTHROPIC_API_KEY}"
      }
    },
    "calculon": {
      "models": {
        "gemma-4-e4b-it-8bit": {
          "attachment": true,
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "name": "gemma-4-e4b-it-8bit"
        },
        "Qwen3.5-9B-MLX-4bit": {
          "attachment": true,
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "name": "Qwen3.5-9B-MLX-4bit"
        }
      },
      "name": "calculon",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "apiKey": "{env:OMLX_API_KEY}",
        "baseURL": "http://calculon.local:8000/v1"
      }
    },
    "google-vertex": {
      "models": {
        "gemini-2.5-flash": {
          "temperature": true
        },
        "gemini-2.5-pro": {
          "temperature": true
        },
        "gemini-3.1-pro-preview": {
          "temperature": true
        }
      },
      "options": {
        "location": "{env:VERTEXAI_REGION}",
        "project": "{env:VERTEXAI_PROJECT_ID}"
      }
    },
    "openai": {
      "models": {
        "gpt-5.1-codex-max": {
          "name": "GPT 5.1 Codex Max (OAuth)",
          "temperature": true
        }
      },
      "options": {
        "include": ["reasoning.encrypted_content"],
        "reasoningEffort": "medium",
        "reasoningSummary": "auto",
        "store": false,
        "textVerbosity": "medium"
      }
    }
  },
  "watcher": {
    "ignore": ["node_modules"]
  }
}
